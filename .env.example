# Backend-only GoldAPI.io key for live gold and silver rates.
# Copy this file to .env and set your real key there.
GOLD_API_KEY="YOUR_GOLDAPI_KEY"

# GEMINI_API_KEY: Required only if Gemini AI API features are used.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="YOUR_APP_URL"
